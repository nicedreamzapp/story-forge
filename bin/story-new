#!/usr/bin/env python3
"""story-new — scaffold a new Story Forge project in one command.

Story Forge is a general video system; this is its front door. Instead of
hand-wiring paths every time, `story-new` lays down a self-contained project
folder with a ready-to-render starter script, a place for your own stills and
cast voices, and a per-project README.

    story-new "My Short Film"
    story-new "Desert Doc" --style photoreal --format narrated-doc
    story-new "Hank Ep 2"   --style pixar-3d  --format film --scenes 4

What you get (under projects/<slug>/):
    <slug>.sf        a runnable starter script (Flux stills, no assets needed)
    stills/          drop your own character/scene art here
    voices/          drop cloned cast voice wavs here
    README.md        how to render, swap art, cast voices, pick a style

Then immediately:
    sf render projects/<slug>/<slug>.sf --out projects/<slug>/<slug>.mp4

The starter renders out of the box because every scene uses a Flux still
prompt. Swap any `still flux:` block for `still image:` + `path:` to use your
own art (the locked method: voice over the untouched animation).
"""

from __future__ import annotations

import argparse
import re
import sys
from pathlib import Path

REPO = Path("/Users/dtribe/Desktop/PROJECTS/AI/videopipe")
if str(REPO) not in sys.path:
    sys.path.insert(0, str(REPO))

from story_forge import packs  # noqa: E402

PROJECTS_DIR = REPO / "projects"


def slugify(name: str) -> str:
    s = re.sub(r"[^A-Za-z0-9]+", "_", name.strip().lower()).strip("_")
    return s or "untitled"


# Generic, style-agnostic scene beats. The style pack's look is appended to the
# Flux prompt automatically by the renderer, so these stay clean and reusable.
_SCENE_BEATS = [
    ("opening",
     "a wide establishing shot of the main location, calm and inviting, "
     "soft natural light",
     "slow ambient drift, gentle light shifts, soft atmosphere, no camera shake",
     "Every story starts somewhere quiet. This one starts here."),
    ("middle",
     "a closer shot of the main character in the location, thoughtful expression",
     "subtle breathing motion, hair and clothing move gently, warm light",
     "Then something changes, and the day stops being ordinary."),
    ("turn",
     "the character looking toward something off-frame with growing interest",
     "a slow push-in, dust motes drift through the light, gentle movement",
     "There is a moment, right before everything tips, that you can feel coming."),
    ("closing",
     "a wide closing shot at golden hour, the location bathed in warm light",
     "slow dolly back, warm sunset glow, soft particles drift through the air",
     "And by the end, nothing looks quite the same as it did at the start."),
]


def build_sf(title: str, slug: str, stills_dir: Path,
             style: str | None, fmt: str | None, n_scenes: int) -> str:
    head_attrs = [f"slug={slug}", "target=m5"]
    if style:
        head_attrs.append(f"style={style}")
    if fmt:
        head_attrs.append(f"format={fmt}")
    else:
        # No format pack to supply a duration → set a sane explicit default.
        head_attrs.append("scene_dur=5.0")
    film_line = f'film "{title}" ' + " ".join(head_attrs)

    lines: list[str] = [
        f"# {title} — Story Forge project",
        f"# Generated by story-new."
        f"  style={style or 'none'}  format={fmt or 'default'}",
        "#",
        "# Render it:",
        f"#   sf render projects/{slug}/{slug}.sf --out projects/{slug}/{slug}.mp4",
        "#",
        "# Use your OWN art for any scene — replace the `still flux:` block with:",
        "#     still image:",
        '#         path: "{$stills}/your_frame.png"',
        "# (the locked method: lay voice over the untouched animation, never repaint mouths)",
        "",
        f'$stills = "{stills_dir}"',
        "",
        film_line,
        "",
        "# --- cast: one narrator voice + one music bed (add more as needed) ---",
        "voice narrator: piper/en_US-libritts_r-medium speaker=0 length=1.10",
        "# For a cloned character voice instead, use:  voice doug: chatterbox/doug",
        "music score: ace/warm-cinematic-underscore vol=0.30",
        "",
        "@transition xfade dur=0.5",
        "@mix duck voice -> music threshold=-22 ratio=4",
        "",
    ]

    beats = _SCENE_BEATS[:max(1, min(n_scenes, len(_SCENE_BEATS)))]
    for name, still_prompt, motion_prompt, narration in beats:
        lines += [
            f"scene {name}:",
            "    still flux:",
            f'        prompt: "{still_prompt}"',
            "    motion ltx:",
            f'        prompt: "{motion_prompt}"',
            "        duration: 5.0",
            "    narrate narrator:",
            f'        line: "{narration}"',
            "    music score vol=0.30",
            "",
        ]
    return "\n".join(lines)


def build_readme(title: str, slug: str, style: str | None,
                 fmt: str | None, proj: Path) -> str:
    style_label = packs.get_style(style)["label"] if style else "none (prompts pass through)"
    fmt_pack = packs.get_format(fmt) if fmt else None
    fmt_label = (f"{fmt_pack['label']} ({fmt_pack['width']}x{fmt_pack['height']} "
                 f"@ {fmt_pack['fps']}fps)") if fmt_pack else "default (1280x720 @ 30fps)"
    styles = ", ".join(s["name"] for s in packs.list_styles())
    formats = ", ".join(f["name"] for f in packs.list_formats())
    return f"""# {title}

A Story Forge project. **Story Forge is a general video system** — this project
can be any kind of video; cartoons are just one thing it does well.

- **Style:** {style_label}
- **Format:** {fmt_label}
- **Script:** `{slug}.sf`

## Render it
```bash
sf render projects/{slug}/{slug}.sf --out projects/{slug}/{slug}.mp4
```
The starter renders out of the box (every scene uses a Flux still prompt — no
assets required). Add `--dry` to print the plan without rendering, or
`--scenes opening,closing` to render a subset.

## Use your own art
Drop images in `stills/`, then in `{slug}.sf` replace a scene's `still flux:`
block with:
```
    still image:
        path: "{{$stills}}/your_frame.png"
```
The locked method: lay voice over the **untouched** animation. Never repaint
mouths.

## Cast voices
Drop cloned voice wavs in `voices/`. Use a cloned character voice in the script
with `voice doug: chatterbox/doug` (Doug = Matt's cloned voice). Built-in
narrator voices use `piper/...`.

## Change the look or shape
Edit the `film` line in `{slug}.sf`:
- `style=` one of: {styles}
- `format=` one of: {formats}

The style is appended to every Flux still prompt; the format sets the
dimensions and fps. List them anytime with `python3 -m story_forge.packs`.
"""


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(prog="story-new",
                                 description="Scaffold a new Story Forge project")
    ap.add_argument("name", help='project name, e.g. "My Short Film"')
    ap.add_argument("--style", default=None,
                    help="style pack (see `python3 -m story_forge.packs`)")
    ap.add_argument("--format", dest="fmt", default=None,
                    help="format pack (film, reel, square, narrated-doc, cinematic)")
    ap.add_argument("--scenes", type=int, default=3,
                    help="number of starter scenes (1-4, default 3)")
    ap.add_argument("--dir", default=None,
                    help="parent dir for the project (default: videopipe/projects)")
    ap.add_argument("--force", action="store_true",
                    help="overwrite an existing project of the same slug")
    args = ap.parse_args(argv)

    # Validate pack names up front so we fail fast with a helpful message.
    try:
        if args.style:
            packs.get_style(args.style)
        if args.fmt:
            packs.get_format(args.fmt)
    except packs.PackError as e:
        print(f"error: {e}", file=sys.stderr)
        return 2

    title = args.name.strip()
    slug = slugify(title)
    parent = Path(args.dir).expanduser() if args.dir else PROJECTS_DIR
    proj = parent / slug

    if proj.exists() and not args.force:
        print(f"error: {proj} already exists (use --force to overwrite)",
              file=sys.stderr)
        return 1

    stills = proj / "stills"
    voices = proj / "voices"
    for d in (proj, stills, voices):
        d.mkdir(parents=True, exist_ok=True)
    (stills / ".gitkeep").touch()
    (voices / ".gitkeep").touch()

    sf_text = build_sf(title, slug, stills, args.style, args.fmt, args.scenes)
    sf_path = proj / f"{slug}.sf"
    sf_path.write_text(sf_text)
    (proj / "README.md").write_text(
        build_readme(title, slug, args.style, args.fmt, proj))

    rel = sf_path
    print(f"✅ created project: {proj}")
    print(f"   script:  {sf_path.name}")
    print(f"   stills/  (drop your own art here)")
    print(f"   voices/  (drop cloned cast voices here)")
    print()
    print("Next:")
    print(f"   sf render {rel} --dry              # see the plan")
    print(f"   sf render {rel} --out {proj/(slug + '.mp4')}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
