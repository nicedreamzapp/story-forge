#!/usr/bin/env python3
"""sf — Story Forge DSL CLI.

Subcommands:
  sf doctor                                                 check render dependencies
  sf parse  FILE.sf [--out PATH]                            parse + emit storyplan
  sf render FILE.sf [--dry] [--out FILE.mp4]
                    [--scenes a,b,c] [--engine lean|full]   compile + render

Defaults:
  --engine lean  → per-scene Flux+render-route+ffmpeg (fast, MVP-grade)
  --engine full  → delegate to story_pipeline.py (overlays, chapter grades)
  --out (omit)   → $SF_OUT_DIR/<slug>.mp4 (default ~/story-forge/outputs)
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

# Ensure the story_forge package is importable when this CLI is run directly,
# from wherever the repo happens to be cloned.
REPO = Path(__file__).resolve().parent.parent
if str(REPO) not in sys.path:
    sys.path.insert(0, str(REPO))

from story_forge.parser import parse, ParseError       # noqa: E402
from story_forge.resolver import resolve, ResolveError  # noqa: E402
from story_forge.emitter import emit_storyplan, write_storyplan  # noqa: E402
from story_forge import run as runner                  # noqa: E402
from story_forge import config as sfconfig              # noqa: E402


def _compile(path: Path) -> tuple[list, dict, dict]:
    try:
        ast = parse(path)
    except ParseError as e:
        print(f"ParseError: {e}", file=sys.stderr)
        raise SystemExit(2)
    try:
        resolved = resolve(ast)
    except ResolveError as e:
        print(f"ResolveError: {e}", file=sys.stderr)
        raise SystemExit(3)
    plan = emit_storyplan(resolved)
    return ast, resolved, plan


def cmd_parse(args: argparse.Namespace) -> int:
    path = Path(args.file)
    ast, resolved, plan = _compile(path)

    print("=== AST ===")
    print(json.dumps(ast, indent=2, default=str))
    print("\n=== STORYPLAN ===")
    print(json.dumps(plan, indent=2, default=str))

    if args.out:
        out_path = write_storyplan(plan, Path(args.out))
        print(f"\nwrote {out_path}", file=sys.stderr)
    return 0


def cmd_render(args: argparse.Namespace) -> int:
    path = Path(args.file)
    _ast, _resolved, plan = _compile(path)
    plan_path = path.with_suffix(".storyplan.json")
    write_storyplan(plan, plan_path)
    print(f"wrote {plan_path}", file=sys.stderr)

    if args.dry:
        cfg = runner.storyplan_to_pipeline_config(plan)
        print(json.dumps(cfg, indent=2, default=str))
        return 0

    slug = plan["film_meta"].get("slug", path.stem)
    out_path = Path(args.out) if args.out else sfconfig.OUT_DIR / f"{slug}.mp4"

    scene_filter = ([s.strip() for s in args.scenes.split(",") if s.strip()]
                    if args.scenes else None)

    result = runner.render(plan_path, dry_run=False,
                           engine=args.engine,
                           out=out_path, scenes=scene_filter)
    print(json.dumps(result, indent=2, default=str))
    return 0


def cmd_doctor(_args: argparse.Namespace) -> int:
    """Say what is missing before a render finds out the hard way."""
    print(sfconfig.format_doctor())
    missing = [r for r in sfconfig.doctor() if not r[1] and r[4]]
    return 1 if missing else 0


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(prog="sf",
                                 description="Story Forge DSL CLI")
    sub = ap.add_subparsers(dest="cmd", required=True)

    p_parse = sub.add_parser("parse", help="parse + emit storyplan")
    p_parse.add_argument("file")
    p_parse.add_argument("--out", help="write storyplan JSON to this path")
    p_parse.set_defaults(func=cmd_parse)

    p_render = sub.add_parser("render", help="parse + storyplan + render mp4")
    p_render.add_argument("file")
    p_render.add_argument("--dry", action="store_true",
                          help="print pipeline config but don't run renderer")
    p_render.add_argument("--out", default=None,
                          help="output mp4 path "
                               "(default: $SF_OUT_DIR/<slug>.mp4)")
    p_render.add_argument("--scenes", default=None,
                          help="comma-separated scene names to render "
                               "(default: all)")
    p_render.add_argument("--engine", choices=["lean", "full"], default="lean",
                          help="lean=per-scene render-route+ffmpeg (fast); "
                               "full=story_pipeline.py with overlays")
    p_render.set_defaults(func=cmd_render)

    p_doctor = sub.add_parser("doctor",
                              help="check the external tools a render needs")
    p_doctor.set_defaults(func=cmd_doctor)

    args = ap.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
